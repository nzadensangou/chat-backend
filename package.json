{
  "name": "chat-backend",
  "version": "1.0.0",
  "description": "Chat application backend with Next.js + Socket.IO (single service)",
  "type": "module",
  "scripts": {
    "dev": "node -r dotenv/config server.js",
    "build": "next build",
    "start": "NODE_ENV=production node -r dotenv/config server.js",
    "lint": "next lint",
    "db:migrate": "knex migrate:latest",
    "db:migrate:make": "knex migrate:make",
    "db:rollback": "knex migrate:rollback",
    "db:rollback:all": "knex migrate:rollback --all",
    "db:seed": "knex seed:run",
    "db:seed:make": "knex seed:make",
    "db:migrate:list": "knex migrate:list",
    "db:reset": "npm run db:rollback:all && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "firebase-admin": "^13.10.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.6.5",
    "next": "^14.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.0.0",
    "pino-pretty": "^13.1.3"
  }
}